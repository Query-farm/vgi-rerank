# name: test/sql/scalars.test
# group: [vgi_rerank]
#
# End-to-end coverage of the cross-encoder rerank scalar through a real ATTACH +
# worker subprocess. Run with haybarn-unittest, so we LOAD vgi explicitly
# (require vgi would SILENTLY SKIP under haybarn). Scores are raw relevance logits
# that vary by ONNX build -- so we never assert exact floats; we assert the
# planted relevant > irrelevant ordering and that ORDER BY rerank_score(:q, doc)
# DESC ranks the relevant candidate first.

require-env VGI_RERANK_WORKER

statement ok
LOAD vgi;

statement ok
ATTACH 'rerank' AS rerank (TYPE vgi, LOCATION '${VGI_RERANK_WORKER}');

# ---- rerank_score(query, document): a DOUBLE relevance score ----------------

query I
SELECT typeof(rerank.rerank_score('reset password', 'click forgot password')) = 'DOUBLE';
----
true

# A clearly relevant document scores higher than a clearly irrelevant one.
query I
SELECT rerank.rerank_score('how do I reset my password',
                           'To reset your password, click the forgot password link.')
     > rerank.rerank_score('how do I reset my password',
                           'Our office is open from nine to five on weekdays.');
----
true

# Explicit-model overload returns a DOUBLE too.
query I
SELECT typeof(rerank.rerank_score('reset password', 'click forgot password',
                                  'Xenova/ms-marco-MiniLM-L-6-v2')) = 'DOUBLE';
----
true

# NULL / empty on either side yields a NULL score (never crashes).
query I
SELECT rerank.rerank_score(NULL, 'a document') IS NULL;
----
true

query I
SELECT rerank.rerank_score('a query', '') IS NULL;
----
true

# ---- the documented usage: ORDER BY over a top-K candidate set --------------

statement ok
CREATE TEMP TABLE candidates AS
  SELECT * FROM (VALUES
    (1, 'Soup recipes for a cold winter evening.'),
    (2, 'Create an index on the most selective columns to speed up large-table scans.'),
    (3, 'A history of the Roman aqueducts.')
  ) AS t(id, chunk);

# Rerank the candidate set by relevance; the on-topic row (id 2) must rank first.
query I
SELECT id
FROM candidates
ORDER BY rerank.rerank_score('best practices for indexing a large table', chunk) DESC
LIMIT 1;
----
2

# The relevant chunk (id 2) outscores BOTH off-topic chunks. (We don't assert an
# order between the two irrelevant chunks -- their relative logits aren't
# meaningful; only "relevant beats irrelevant" is.)
query I
SELECT bool_and(
         rerank.rerank_score('best practices for indexing a large table',
                             (SELECT chunk FROM candidates WHERE id = 2))
         > rerank.rerank_score('best practices for indexing a large table', chunk))
FROM candidates
WHERE id IN (1, 3);
----
true

# A NULL document in the candidate set scores NULL (and sorts last under DESC).
statement ok
INSERT INTO candidates VALUES (4, NULL);

query I
SELECT rerank.rerank_score('indexing', chunk) IS NULL FROM candidates WHERE id = 4;
----
true

# ---- rerank_version ---------------------------------------------------------

query I
SELECT rerank.rerank_version() LIKE 'vgi-rerank%';
----
true

statement ok
DETACH rerank;
